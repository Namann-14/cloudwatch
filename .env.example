# ── Server ────────────────────────────────────────────────────
PORT=8000

# ── CORS ──────────────────────────────────────────────────────
# Origin allowed to call the API (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX=20             # Max requests per window per IP

# ── AI / LLM ──────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email — Resend (https://resend.com) ───────────────────────
# Sign up for free at https://resend.com, create an API key
RESEND_API_KEY=re_your_api_key_here
# Sender address — must be a verified domain on your Resend account
# Use "onboarding@resend.dev" for quick testing (sends only to your own inbox)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Frontend (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
