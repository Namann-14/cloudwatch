# ── Server ────────────────────────────────────────────────────
PORT=8000

# ── CORS ──────────────────────────────────────────────────────
# Origin allowed to call the API (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX=20             # Max requests per window per IP

# ── AI / LLM ──────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email — EmailJS (https://emailjs.com) ─────────────────────
# Sign up at https://emailjs.com → Email Services → Add Service
EMAILJS_SERVICE_ID=service_xxxxxxx
# EmailJS → Email Templates → your template ID
EMAILJS_TEMPLATE_ID=template_xxxxxxx
# EmailJS → Account → API Keys → Public Key
EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
# EmailJS → Account → API Keys → Private Key (for server-side use)
EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Frontend (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
